PORT=5001
NODE_ENV=production
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/garments_mobile
CHAT_MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/garments_mobile_chat
JWT_SECRET=replace_with_a_long_random_secret
BASE_URL=http://your-server-ip-or-domain:5001
# Comma-separated origins for web clients. Leave empty to allow all.
CORS_ORIGIN=http://localhost:3000,http://localhost:5000

# Optional integrations
OPENAI_API_KEY=
GEMINI_API_KEY=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=
AWS_BUCKET_NAME=
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
